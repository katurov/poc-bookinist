# --- Solana Configuration ---
# Your Solana wallet private key. Format: [1, 2, 3...] (byte array) or Base58 string.
# Required for signing transactions and identifying the agent.
SOLANA_PRIVATE_KEY=[0,0,0...0]

# Solana RPC node URL. Use devnet for testing or mainnet-beta for production.
SOLANA_RPC_URL=https://api.devnet.solana.com

# --- Agent Manifest Information ---
# Public name of your agent that will be visible in the registry.
AGENT_NAME=BalkanGastroNode

# Broad category or niche your agent specializes in.
AGENT_NICHE=regional_gastronomy

# Keywords associated with your agent for discovery.
AGENT_TAGS=serbia,restaurants,food

# The price for your agent's services, denominated in SOL.
AGENT_BASE_PRICE_SOL=0.001

# The API endpoint where your agent can be reached for data or tasks.
# Should point to your running server (e.g., bookinist/server_main.py).
AGENT_ENDPOINT=http://localhost:3333/v1/

# A detailed description of what your agent does.
AGENT_DESCRIPTION=Provides structured datasets and ratings for dining establishments in Serbia.

# --- Protocol Configuration ---
# The public key of the Author Registry program on Solana.
REGISTRY_PUBKEY=AUcZfbvuHswRZZy8nQybxZ6KezckoqNRqQCPVv17BrtD
